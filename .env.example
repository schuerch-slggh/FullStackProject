# Vorlage für lokale Konfiguration. Kopieren nach `.env` und Werte eintragen:
#   cp .env.example .env
# `.env` selbst ist in .gitignore und wird NIE committet.

# Session-/CSRF-Sicherheit (Flask-WTF)
SECRET_KEY=dev-secret-change-me

# Datenbank (leer = lokale SQLite in instance/app.db)
# DATABASE_URL=mysql+pymysql://user:pass@localhost:3306/db

# E-Mail-Notification (FA-10) — leer = nur Log, keine echten Mails
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=1
MAIL_USERNAME=deine-adresse@gmail.com
MAIL_PASSWORD=app-passwort-hier-einfuegen
MAIL_SENDER=deine-adresse@gmail.com

# KI-Coach (FA-11) — leer = lokaler Fallback ohne externe API
ANTHROPIC_API_KEY=
